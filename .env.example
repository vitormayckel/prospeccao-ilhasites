# Trava de acesso (uso interno) — HTTP Basic Auth via middleware.
# Se AMBOS estiverem definidos, todo acesso exige usuário/senha.
# Se ausentes, não há trava (desenvolvimento local).
# BASIC_AUTH_USER=ilha
# BASIC_AUTH_PASSWORD=troque-esta-senha

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Criar no Supabase:
# 1. Vá em supabase.com e crie um projeto
# 2. Vá em Settings > API
# 3. Copie a URL e a anon key

# Banco (produção). Se definido, usa postgres.js; senão usa PGlite local (.pglite).
# DATABASE_URL=postgres://user:pass@host:5432/db

# Google Places API (New) — provedor de coleta da Fase 4.
# Habilita a coleta real; sem esta chave o provedor "google_places" fica
# desabilitado (o provider "fixture" continua funcionando para dev).
# Como obter:
# 1. console.cloud.google.com > crie/selec. um projeto e ative o billing
# 2. Ative "Places API (New)"
# 3. APIs e Serviços > Credenciais > Criar chave de API (restrinja à Places API New)
# GOOGLE_PLACES_API_KEY=sua-chave-aqui
# GOOGLE_PLACES_COST_PER_REQUEST=0.032   # opcional: custo estimado por requisição (US$)

# Dev: permite que perfis "google_places" caiam no fixture sem custo.
# COLLECTION_ALLOW_FIXTURE_FALLBACK=true

# Análise por IA (Fase 5) — Anthropic (Claude).
# Sem esta chave, a análise usa o provedor "fixture" (heurístico, sem custo).
# Obtenha em console.anthropic.com (billing ativo).
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-5          # alternativa mais barata: claude-haiku-4-5-20251001
# ANALYSIS_PROVIDER=anthropic              # força o provedor (anthropic|fixture)
# ANTHROPIC_COST_PER_MTOK_INPUT=3          # estimativa de custo (US$/1M tokens de entrada)
# ANTHROPIC_COST_PER_MTOK_OUTPUT=15        # estimativa de custo (US$/1M tokens de saída)

# ---------------------------------------------------------------------
# Pipeline persistente de prospecção (FASE 2)
# ---------------------------------------------------------------------
# Segredo das rotas internas de jobs (/api/jobs/*). OBRIGATÓRIO em produção:
# sem ele o encadeamento de ticks não acontece e as rotas negam tudo.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JOBS_TICK_SECRET=

# URL absoluta da aplicação, usada para o encadeamento chamar a si mesma.
# Na Vercel, VERCEL_URL já é injetada e serve de fallback automático.
# APP_URL=https://seu-app.vercel.app

# Assinatura do Cron da Vercel (definida automaticamente pela plataforma).
# CRON_SECRET=

# Análises de IA simultâneas por tick. Conservador de propósito.
# ANALYSIS_CONCURRENCY=2

# Orçamento de trabalho por tick, em milissegundos (padrão 8000, teto 60000).
# No Hobby, 8000 fica seguro abaixo do limite de função. Ao migrar para o Pro,
# aumentar este valor é a única mudança necessária: menos ticks, mesmo pipeline.
# JOBS_TICK_BUDGET_MS=8000

# Piso de score para qualificar uma oportunidade. 0 = desativado, ou seja,
# nenhuma empresa é desclassificada por nota (comportamento atual preservado).
# PIPELINE_MIN_SCORE=0
