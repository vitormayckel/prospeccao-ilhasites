{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm install *)",
      "Bash(npx shadcn@latest add *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(mkdir *)",
      "Bash(bash .claude/hooks/welcome.sh)"
    ],
    "deny": ["Bash(rm -rf *)", "Bash(sudo *)", "Bash(curl *)", "Bash(wget *)"]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/welcome.sh"
          }
        ]
      }
    ]
  }
}
